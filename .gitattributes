# Normalize line endings on commit; check out with platform-native endings
* text=auto

# Always LF for source files
*.py  text eol=lf
*.md  text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.in  text eol=lf
*.sh  text eol=lf

# Keep CRLF for Windows scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
